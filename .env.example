# ============================================================
# IAM Policy Analyzer — Environment Configuration
# Copy to .env and fill in values. Never commit .env.
# Run: make setup  (auto-generates JWT_SECRET for you)
# ============================================================

# === Core ===
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
NEO4J_PASSWORD=changeme
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET
APP_ENV=development
# Requests per hour per user (default: 1000)
RATE_LIMIT_PER_HOUR=1000

# === Admin Bootstrap ===
# Used on first startup to seed the admin account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe1!

# === LLM (optional) ===
# Required only for AI-powered policy analysis features
GEMINI_API_KEY=your-gemini-api-key-here

# === Cloud Scanners — OPTIONAL ===
# The app works fully without these (file-upload analysis always available).
# Set only the cloud(s) you want to scan live.

# -- AWS --
# Uses boto3 default credential chain (env vars, ~/.aws/credentials, IAM role).
# No extra vars needed unless overriding the default chain.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# -- Azure --
# Service principal credentials for RBAC live scan
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_SUBSCRIPTION_ID=

# -- GCP --
# Either inline JSON key or path to key file (not both)
# GCP_PROJECT_ID=
# GCP_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
